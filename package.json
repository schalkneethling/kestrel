{
  "name": "kestrel",
  "version": "0.0.0",
  "private": true,
  "description": "Single-user job posting tracker for ATS polling, repost detection, criteria matching, and desktop notifications.",
  "license": "MIT",
  "author": "Schalk Neethling",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @kestrel/dashboard dev",
    "worker:dev": "pnpm --filter @kestrel/worker dev",
    "db:migrate:local": "pnpm --filter @kestrel/worker db:migrate:local",
    "build": "pnpm --recursive --if-present run build",
    "preview": "pnpm --filter @kestrel/dashboard preview",
    "prepare": "vp config",
    "lint": "oxlint . && stylelint \"**/*.{css,scss}\"",
    "lint:fix": "oxlint --fix . && stylelint \"**/*.{css,scss}\" --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "actionlint": "node scripts/workflow-quality.mjs actionlint",
    "zizmor": "node scripts/workflow-quality.mjs zizmor",
    "quality": "pnpm actionlint && pnpm zizmor && pnpm lint && pnpm format:check && pnpm react:doctor",
    "test": "pnpm --recursive --if-present run test",
    "test:watch": "pnpm --recursive --if-present run test:watch",
    "react:doctor": "react-doctor --offline",
    "react:doctor:diff": "react-doctor --offline --diff",
    "env:validate": "varlock load --agent",
    "env:validate:production": "APP_ENV=production varlock load --agent",
    "secrets:scan": "varlock scan",
    "secrets:scan:staged": "varlock scan --staged"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@varlock/cloudflare-integration": "^1.2.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "react-doctor": "^0.7.2",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-plugin-use-baseline": "^1.4.4",
    "typescript": "~6.0.2",
    "varlock": "^1.10.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4",
    "vitest": "4.1.10",
    "wrangler": "^4.107.1"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vitest": "4.1.10"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.11.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.11.0"
}
